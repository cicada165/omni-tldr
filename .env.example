# =====================================================
# omni-discord — Environment Variables
# Copy this file to .env.local and fill in the values
# =====================================================

# ── Discord ────────────────────────────────────────
# Create a bot at: https://discord.com/developers/applications
# Give it "Read Message History" + "View Channels" permissions
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Comma-separated Discord channel IDs to monitor
# Right-click a channel in Discord (Developer Mode ON) → Copy Channel ID
DISCORD_CHANNEL_IDS=123456789012345678,234567890123456789

# How many messages to fetch per channel per run (default: 100)
DISCORD_MESSAGES_LIMIT=100

# ── LLM (OpenAI) ──────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Model to use for summaries (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ── Upstash Redis (Database) ──────────────────────
# Vercel KV is now powered by Upstash. In Vercel dashboard:
#   Storage → Connect Store → Upstash Redis (free tier available)
# Or go directly to: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Also add Discord Server ID (default is already set in code)
DISCORD_SERVER_ID=1419986599340675155

# ── Security ──────────────────────────────────────
# Secret to authenticate the cron endpoint (generate a random string)
# openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# ── App Config ────────────────────────────────────
NEXT_PUBLIC_APP_NAME=omni-discord
NEXT_PUBLIC_APP_DESCRIPTION=Discord Investment Intelligence Dashboard
